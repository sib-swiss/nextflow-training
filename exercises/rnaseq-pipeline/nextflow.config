docker.enabled = true
conda.enabled = false

profiles {

    my_laptop {
        process.executor = 'local'
        docker.enabled = true
    }
    univ_hpc {
        process.executor = 'slurm'
        conda.enabled = true
        process.resourceLimits = [
            memory: 750.GB,
            cpus: 200,
            time: 30.d
        ]
    }
    test {
        params.input = "data/paired-end.csv"
        params.hisat2_index_zip = "data/genome_index.tar.gz"
        params.report_id = "all_paired-end"
    }
}
