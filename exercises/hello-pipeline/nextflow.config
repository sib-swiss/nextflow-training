docker.enabled = true

/*
* Process settings
*/
process {
    memory = 1.GB
    withName: 'cowpy' {
        memory = 2.GB
        cpus = 2
    }
}

/*
* Pipeline parameters
*/
params {
    input = "${projectDir}/data/greetings.csv"
    batch = 'batch'
    character = 'turkey'
}

/*
* Output settings
*/
outputDir = "results/${params.batch}"
workflow.output.mode = 'copy'
